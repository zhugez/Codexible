# Server
HOST=0.0.0.0
PORT=3001
RUST_LOG=info

# Database
DATABASE_URL=postgres://codexible:password@localhost:5432/codexible

# Redis
REDIS_URL=redis://localhost:6379

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://codexible.me

# Security
API_KEY_HMAC_SECRET=change_me_to_a_random_64_char_hex_string

# Performance controls
ENABLE_RATE_LIMIT=true
ENABLE_QUOTA_ENFORCEMENT=true
ENABLE_USAGE_METERING=true
REQUEST_COST_CREDITS=1

# CLIProxyAPI integration
CLIPROXY_INTEGRATION_ENABLED=false
CLIPROXY_UPSTREAM_URL=http://127.0.0.1:8317
CLIPROXY_MANAGEMENT_URL=http://127.0.0.1:8317/v0/management
CLIPROXY_MANAGEMENT_KEY=
CLIPROXY_TIMEOUT_MS=8000
CLIPROXY_DEFAULT_DAILY_LIMIT=1000
CLIPROXY_ADMIN_TOKENS=

# Admin controls
ADMIN_EMAILS=admin@codexible.me
ADMIN_LOG_MAX_ENTRIES=500
